# dependencies
node_modules

# agent-local git worktrees
.worktrees/

# build outputs
dist/
dist-env/
dist-server/
release/
release-steam/
# generated main-process runtime bundles (scripts/electron-vendor.mjs)
electron/vendor/
media-cache/
sfx-runtime/

# i18n per-locale emit crash leftovers (the build sweeps these; never commit one)
src/ui/i18n.resolved.generated/*.tmp
src/admin/i18n.resolved.generated/*.tmp

# i18n status registry + its counts summary: build/test-only (the registry is ~4.7 MB),
# regenerated by `pretest` and the CI `npm run i18n:gen` step before any test reads it;
# never shipped, never reviewed. Both the full registry and the counts summary are
# generated and gitignored; the audit trail is posted out-of-band to the CI job summary
# by the coverage-summary step.
src/ui/i18n.status.json
src/ui/i18n.status.summary.json

# private extensions (e.g. bot-detector)
private/*
!private/.dockerkeep

# test artifacts & screenshots
tmp/
# PR-assist screenshot tour output + its CI-only ephemerals
pr-shots/
pr.diff
.devpid
.codex-research/
# Codex local state stays ignored; shared project configuration and agents are tracked.
.codex/*
!.codex/config.toml
!.codex/hooks.json
!.codex/agents/
!.codex/agents/*.toml
!.codex/hooks/
!.codex/hooks/*.sh
.playwright-mcp/
# Vitest Browser Mode failure screenshots + attachments (opt-in test:browser suite)
tests/browser/__screenshots__/
.vitest-attachments/
# Mobile safe-area E2E before/after PNG output (scripts/mobile_*_safe_area.mjs)
screenshots/

# i18n release-fill worklist (generated; regenerate via `npm run i18n:worklist`)
docs/i18n-scaling/worklist/

# python
__pycache__/
*.pyc
.venv/

# environment / secrets
.env
.env.*
!.env.example
AuthKey_*.p8
# Meshy asset-gen tooling embeds an API key, never commit it
scripts/generate_treasure_chest.mjs

# editor & OS noise
.DS_Store
Thumbs.db
*.log
.idea/
# .claude/: keep personal/local config out of git, but track the shared team tooling
# (agents, skills, commands, hooks, and the project hooks config). settings.local.json,
# which is personal/local, stays ignored by the .claude/* rule above.
.claude/*
!.claude/skills/
!.claude/agents/
!.claude/commands/
!.claude/hooks/
!.claude/settings.json
.cursor/

# local SDK/tooling dump (extracted command-line tools, not project source)
postgres/

pr-assets-2fa

.vite/

# Discord app credentials + bot token, never commit it
discord_bot_info.txt

# bot build output
dist-bot/

# Local multibox / farming automation + session logs (never part of the game repo)
/logs/
/memory/
/multibox.tokens.json
/scripts/multibox*
/scripts/agent/
/scripts/companion.*
/scripts/browser_auth.mjs
/scripts/token_sink.mjs
/scripts/_farm_supervisor.sh
/scripts/_multibox_backup/
/scripts/MULTIBOX.md
/scripts/hunter_agent*.mjs
/scripts/hunter_agents.sh
/scripts/gravewyrm_trio.mjs
/TESTING-TALENTS-2-0.md
