# World of Claudecraft server configuration — copy to .env and edit:
#   cp .env.example .env
# The game server loads .env automatically; docker compose reads it too.

# Postgres password for the eastbrook database (docker compose requires it).
# Make it long and random for anything reachable from the internet.
POSTGRES_PASSWORD=change-me

# Connection string the game server uses. Only needed when running
# `npm run server` outside docker — compose builds its own from
# POSTGRES_PASSWORD. The dev database from `npm run db:up` listens on
# 127.0.0.1:5433; keep this password in sync with POSTGRES_PASSWORD.
DATABASE_URL=postgres://eastbrook:change-me@127.0.0.1:5433/eastbrook

# HTTP + WebSocket port for the game server (default 8787).
#PORT=8787

# Host directory mounted at /app/dist/media so content-hashed media files stay
# available across container replacements. The Ansible deploy sets this to an
# absolute /opt/eastbrook path in production.
EASTBROOK_MEDIA_DIR=./media-cache

# MediaWiki runs as a separate service for the player wiki.
# Local URL: http://localhost:8080/wiki/
MEDIAWIKI_DB_NAME=mediawiki
MEDIAWIKI_DB_USER=mediawiki
MEDIAWIKI_DB_PASSWORD=mediawiki-change-me
MEDIAWIKI_ADMIN_USER=WikiAdmin
MEDIAWIKI_ADMIN_PASS=change-me-admin-password
# IMPORTANT (production): set this to the PUBLIC origin, NOT localhost. MediaWiki
# builds absolute URLs / redirects from it, so a localhost value sends real
# visitors to http://localhost:8080/... The reverse proxy must route /wiki* to
# this service (see DEPLOY.md). e.g. MEDIAWIKI_SERVER=https://worldofclaudecraft.com
MEDIAWIKI_SERVER=http://localhost:8080
# Optional production secrets. Set long random values before exposing publicly.
#MEDIAWIKI_SECRET_KEY=
#MEDIAWIKI_UPGRADE_KEY=
# Game-server redirect target when someone opens /wiki on the game port directly.
# In production set this to the public wiki URL, NOT localhost — otherwise the
# fallback below 302-redirects visitors to their own machine.
# e.g. WIKI_URL=https://worldofclaudecraft.com/wiki/index.php/Main_Page
WIKI_URL=http://localhost:8080/wiki/index.php/Main_Page

# Realm (world/shard) this process serves (default "Claudemoon"). Characters,
# friends, guilds, and presence are all scoped to it. To run multiple isolated
# realms, start one process per realm — same DATABASE_URL, a different
# REALM_NAME and PORT each — e.g. REALM_NAME=Ironforge PORT=8788. Letters,
# digits, spaces, and ' _ - up to 24 chars; invalid values fall back to default.
#REALM_NAME=Claudemoon

# Type of this process's own realm (Normal | PvP | RP | RP-PvP). Default Normal.
# Only used for the single-realm default directory; multi-realm uses REALMS.
#REALM_TYPE=Normal

# Optional realm directory powering the client's WoW-style Realm List screen.
# Comma-separated `Name=https://origin=Type` entries (Type optional → Normal);
# every realm process should advertise the same list. Unset → a single
# same-origin realm. Cross-origin realms here are also the CORS allowlist.
#REALMS=Claudemoon=https://claudemoon.example.com=Normal,Ironforge=https://ironforge.example.com=PvP

# Public origin used for absolute server-generated URLs such as player-card
# Open Graph metadata. In multi-realm deployments, the matching REALMS entry is
# used when this is unset. Set this for single-realm production.
#PUBLIC_ORIGIN=https://worldofclaudecraft.com

# How many days of chat logs to keep (default 90; 0 = keep forever).
#CHAT_LOG_RETENTION_DAYS=90

# Comma-separated reverse-proxy IPs whose X-Forwarded-For header is trusted
# when rate-limiting. Default trusts loopback + private ranges, which is
# right for the compose + local reverse proxy setup; pin an explicit list
# if your proxy connects from elsewhere.
#TRUSTED_PROXY_IPS=

# Cloudflare Turnstile secret key. Gates POST /api/register and POST /api/login:
# when set, requests must carry a Turnstile token that verifies against
# Cloudflare, which blocks headless bot clients (they cannot solve the challenge).
# UNSET = verification skipped entirely (the local/dev default), so the gate ships
# DISABLED unless you set this in production. Pair it with VITE_TURNSTILE_SITEKEY.
#TURNSTILE_SECRET=

# Secret for POST /internal/restart-countdown. The deploy playbook calls this
# loopback-only endpoint before restarting production so players see warnings.
# Set this to a long random value and mirror it in Ansible secrets.
#RESTART_COUNTDOWN_SECRET=

# Cloudflare Turnstile SITE key (public) for the login/register widget. NOTE: this
# is read by the CLIENT and inlined at BUILD time (`vite build`/`npm run build`),
# NOT at server runtime — it must be present in the build environment, not just on
# the server. Unset → the widget never renders and no token is sent. Use a separate
# Turnstile widget (key pair) per environment; dev/prod differ. See DEPLOY.md.
#VITE_TURNSTILE_SITEKEY=

# DANGER: enables the level/teleport/item cheat commands used by the test
# bots (scripts/crypt_raid.mjs etc). Never set this on a public server.
#ALLOW_DEV_COMMANDS=1

# ElevenLabs API key — used ONLY by the offline NPC-voice generation scripts
# (scripts/gen_npc_voices.mjs designs the voices, scripts/gen_npc_lines.mjs
# synthesizes the line mp3s into public/audio/voice). Not read by the game server
# or client at runtime. Generate one at https://elevenlabs.io and keep it secret.
#ELEVENLABS_API_KEY=

# Optional client-side kill switch for the non-custodial Solana wallet-link UI.
# The wallet flow uses injected browser wallets and does not need a third-party
# wallet-connect project id. Set this only if a deploy should hide wallet UI.
#VITE_WALLET_DISABLED=1

# Solana RPC endpoint for reading $WOC balances (mainnet). SERVER-SIDE ONLY: the
# client reads balances through the server proxy (GET /api/woc/balance), so this
# URL (and any API key in it, e.g. Helius/QuickNode/Triton) is NEVER shipped in
# the client bundle. The public default is heavily rate-limited; set a dedicated
# endpoint in production. NOT prefixed VITE_: keep it off the client.
#SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# The $WOC SPL token mint the server reads balances against. Defaults to the
# published contract; override only if the canonical mint changes. Server-side.
#WOC_MINT=3WjLscH2JsXLEFJZRA9z8ti8yRGxWGKbqymPd7UicRth
# (For local dev, server/db.ts also loads .env.local, so VITE_SOLANA_RPC_URL /
#  VITE_WOC_MINT there are still honored as a fallback, but no client code reads
#  them, so they are never inlined into the build.)
