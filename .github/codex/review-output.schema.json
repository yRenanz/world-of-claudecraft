{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["assessment", "summary", "findings"],
  "properties": {
    "assessment": {
      "type": "string",
      "enum": ["looks_correct", "needs_changes", "blocked"]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "findings": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "category", "path", "line", "message", "recommendation"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "category": {
            "type": "string",
            "enum": ["correctness", "security", "invariants", "tests", "maintainability"]
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2000
          },
          "recommendation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    }
  }
}
